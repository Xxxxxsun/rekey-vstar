# Copy to .env or export these variables in your shell.

# Required for REKEY image regeneration with OpenAI's Image API.
OPENAI_API_KEY=
DYNAMIC_VSTAR_IMAGE_MODEL=gpt-image-2

# Optional: override the image-edit endpoint or multipart image field for a
# compatible provider. The defaults target OpenAI's /v1/images/edits endpoint.
# DYNAMIC_VSTAR_IMAGE_API_URL=https://api.openai.com/v1/images/edits
# DYNAMIC_VSTAR_IMAGE_FIELD=image[]

# Optional: use an OpenRouter-backed planner instead of the deterministic
# rule-based planner.
OPENROUTER_API_KEY=
DYNAMIC_VSTAR_PLANNER_MODEL=

# Optional: publish/download the released benchmark on Hugging Face.
HF_TOKEN=
REKEY_DATASET_REPO=Xfgll/rekey-vstar-benchmark
